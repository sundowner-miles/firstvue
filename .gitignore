# 系统临时文件
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE 编辑器配置
.idea/
.vscode/
*.iml
*.ipr

# ========== 前端 firstvue 忽略项 ==========
# 依赖包（体积巨大，严禁提交）
firstvue/node_modules/
# 打包产物
firstvue/dist/
firstvue/build/
# 环境变量、日志
firstvue/.env*
firstvue/npm-debug.log*
firstvue/yarn-debug.log*
firstvue/yarn-error.log*

# ========== 后端 backend 忽略项 ==========
# Java 编译输出、Jar 包
backend/target/
backend/out/
# 日志
backend/*.log
backend/logs/
# 头像/文件上传目录（本地文件，不上传远程）
backend/uploads/
# JVM 崩溃文件
backend/heapdump.*
backend/*.hprof